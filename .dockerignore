# Ignore git metadata
.git
.gitignore
.gitattributes

# Ignore backend build artifacts
target/
backend/target/

# Ignore frontend build and tool artifacts (local)
frontend/build/
frontend/.dart_tool/
frontend/.packages
frontend/.pub-cache/
frontend/.pub/

# Ignore large documents and assets in root
*.pdf
*.docx
*.zip
*.bat
*.ps1

# Ignore local scratch and temporary files
backend/scratch.rs
backend/src/scratch_promotion.rs
*.py
*.log

# Ignore IDE / OS config directories
.vscode/
.idea/
.DS_Store
Thumbs.db
